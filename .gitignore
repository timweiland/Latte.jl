*.jl.*.cov
*.jl.cov
*.jl.mem
/Manifest.toml
/docs/Manifest.toml
/docs/build/
# Generated tutorial outputs (sources live in docs/src/literate-tutorials/);
# only the hand-written landing page is tracked.
/docs/src/tutorials/*
!/docs/src/tutorials/index.md
# Local scratch — kept out of the public repo. Loose notes/experiments get
# collected under .scratch/; the dirs below stay in place but are ignored.
.DS_Store
/.scratch/
.agent-archive
/tasks/
/prototypes/
/.claude/agents/
/.claude/plans/
# Scaling-benchmark meshes are regenerated by gen_meshes.R; track only the
# small level definitions and the curve results, not the heavy mesh CSVs.
/benchmark/scaling/_workdir/*
!/benchmark/scaling/_workdir/levels.json
!/benchmark/scaling/_workdir/latte_curve.json
!/benchmark/scaling/_workdir/rinla_curve.json
